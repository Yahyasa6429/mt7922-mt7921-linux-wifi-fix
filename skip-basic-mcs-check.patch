--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -356,6 +356,13 @@ ieee80211_verify_sta_ht_mcs_support(struct ieee80211_sub_if_data *sdata,
 	if (!ht_op)
 		return false;

+	/*
+	 * Skip basic MCS set validation. Some 4x4 APs (e.g. Xfinity XB8,
+	 * many ISP gateways) advertise multi-stream basic MCS rates that
+	 * 2x2 STAs (e.g. MediaTek MT7921/MT7922) cannot meet, causing
+	 * mac80211 to disable HT entirely and fall back to 54 Mbit/s.
+	 * The STA still works fine using its own supported rates.
+	 */
+	return true;
 	memcpy(&sta_ht_cap, &sband->ht_cap, sizeof(sta_ht_cap));
 	ieee80211_apply_htcap_overrides(sdata, &sta_ht_cap);

